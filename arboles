<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Raíz y Lienzo — Cuadros de árboles pintados a mano</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,500&family=Work+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --forest:#2F4B3C;
    --forest-dark:#213529;
    --moss:#75937A;
    --bark:#7A4A26;
    --bark-dark:#5F3A1D;
    --linen:#F6F1E6;
    --linen-soft:#EEE6D5;
    --card:#FDFBF6;
    --ink:#2A2621;
    --muted:#726A5C;
    --line:#DED4BE;
    --radius:14px;
  }
  *{box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    margin:0;
    background:var(--linen);
    color:var(--ink);
    font-family:'Work Sans', sans-serif;
    font-size:16px;
    line-height:1.55;
  }
  h1,h2,h3,.display{
    font-family:'Fraunces', serif;
    font-weight:500;
    letter-spacing:-0.01em;
    margin:0;
    color:var(--forest-dark);
  }
  a{color:inherit;}
  img,svg{display:block;max-width:100%;}
  .wrap{max-width:1180px;margin:0 auto;padding:0 28px;}
  :focus-visible{outline:3px solid var(--bark); outline-offset:3px;}

  /* ---------- header ---------- */
  header{
    position:sticky; top:0; z-index:50;
    background:rgba(246,241,230,0.86);
    backdrop-filter:blur(8px);
    border-bottom:1px solid var(--line);
  }
  .nav{
    display:flex; align-items:center; justify-content:space-between;
    padding:18px 0;
  }
  .brand{
    display:flex; align-items:center; gap:10px;
    font-family:'Fraunces', serif; font-weight:600; font-size:22px;
    color:var(--forest-dark); text-decoration:none;
  }
  .brand svg{width:30px;height:30px;}
  nav ul{list-style:none; display:flex; gap:34px; margin:0; padding:0;}
  nav a{text-decoration:none; font-size:14.5px; font-weight:500; color:var(--forest-dark); position:relative;}
  nav a:hover{color:var(--bark);}
  .menu-btn{
    display:none; background:none; border:1px solid var(--line); border-radius:8px;
    width:40px; height:40px; align-items:center; justify-content:center; cursor:pointer;
  }
  .menu-btn svg{width:20px;height:20px;}
  .mobile-menu{
    display:none; list-style:none; margin:0; padding:6px 28px 18px;
    flex-direction:column; gap:4px;
  }
  .mobile-menu.open{display:flex;}
  .mobile-menu a{
    display:block; padding:12px 4px; text-decoration:none; font-weight:500;
    color:var(--forest-dark); border-top:1px solid var(--line); font-size:15px;
  }

  /* ---------- hero ---------- */
  .hero{
    background:var(--forest-dark);
    color:#F1ECE0;
    position:relative;
    overflow:hidden;
  }
  .hero .wrap{
    display:grid; grid-template-columns:1.05fr 0.95fr; align-items:center;
    gap:40px; padding-top:78px; padding-bottom:78px; min-height:560px;
  }
  .eyebrow{
    font-size:13px; letter-spacing:0.14em; text-transform:uppercase;
    color:#C7D0C0; font-weight:600; margin-bottom:18px; display:block;
  }
  .hero h1{
    font-size:clamp(38px, 5vw, 58px);
    line-height:1.06;
    color:#FBF8F1;
  }
  .hero h1 em{ font-style:italic; color:#CFAE7F; }
  .hero p.lead{
    margin-top:22px; max-width:440px; color:#DAD5C6; font-size:17px;
  }
  .hero-cta{ display:flex; gap:16px; margin-top:34px; flex-wrap:wrap; }
  .btn{
    display:inline-flex; align-items:center; gap:8px;
    padding:13px 26px; border-radius:999px; font-weight:600; font-size:14.5px;
    text-decoration:none; border:1px solid transparent; cursor:pointer;
    transition:transform .15s ease, background .15s ease, color .15s ease;
  }
  .btn-primary{background:#CFAE7F; color:#2A2116;}
  .btn-primary:hover{transform:translateY(-2px); background:#DCC198;}
  .btn-ghost{border-color:#5A6E5D; color:#F1ECE0;}
  .btn-ghost:hover{border-color:#CFAE7F; color:#CFAE7F;}

  .hero-art{ position:relative; }
  .rings{
    position:absolute; inset:-60px -30px auto auto; width:340px; opacity:0.14;
  }

  /* ---------- section headers ---------- */
  .section{padding:88px 0;}
  .section-head{
    display:flex; justify-content:space-between; align-items:flex-end;
    gap:24px; margin-bottom:46px; flex-wrap:wrap;
  }
  .section-head h2{ font-size:clamp(28px,3.4vw,38px); }
  .section-head p{ color:var(--muted); max-width:420px; font-size:15px; margin:10px 0 0; }
  .eyebrow-dark{color:var(--bark);}

  /* divider motif: growth rings */
  .divider{
    display:flex; align-items:center; justify-content:center;
    padding:6px 0 0;
  }
  .divider svg{width:64px; height:64px; opacity:0.55;}

  /* ---------- gallery ---------- */
  .gallery{
    display:grid; grid-template-columns:repeat(3, 1fr); gap:30px;
  }
  .art-card{
    background:var(--card); border-radius:var(--radius);
    border:1px solid var(--line);
    overflow:hidden;
    transition:transform .2s ease, box-shadow .2s ease;
  }
  .art-card:hover{ transform:translateY(-5px); box-shadow:0 18px 34px -18px rgba(42,38,33,0.28); }
  .art-frame{
    aspect-ratio:4/5; background:var(--linen-soft);
    display:flex; align-items:center; justify-content:center;
    position:relative;
  }
  .art-frame svg{width:64%; height:64%;}
  .tag{
    position:absolute; top:14px; left:14px;
    background:var(--forest-dark); color:#F1ECE0;
    font-size:11px; font-weight:600; letter-spacing:.04em;
    padding:5px 10px; border-radius:999px; text-transform:uppercase;
  }
  .art-body{padding:20px 22px 24px;}
  .art-body h3{font-size:19px; font-weight:500;}
  .art-meta{color:var(--muted); font-size:13.5px; margin-top:4px;}
  .art-footer{
    display:flex; align-items:center; justify-content:space-between;
    margin-top:16px; padding-top:14px; border-top:1px solid var(--line);
  }
  .price{font-family:'Fraunces', serif; font-size:20px; color:var(--bark-dark); font-weight:600;}
  .mini-link{font-size:13px; font-weight:600; color:var(--forest); text-decoration:none;}
  .mini-link:hover{color:var(--bark);}

  /* ---------- otros articulos ---------- */
  .otros-wrap{background:var(--linen-soft); border-top:1px solid var(--line); border-bottom:1px solid var(--line);}
  .otros-grid{ display:grid; grid-template-columns:repeat(3,1fr); gap:26px; }
  .otro-card{
    background:var(--card); border:1px solid var(--line); border-radius:var(--radius);
    padding:28px 24px; display:flex; flex-direction:column; gap:14px;
  }
  .otro-icon{
    width:50px; height:50px; border-radius:50%;
    background:var(--forest); display:flex; align-items:center; justify-content:center;
  }
  .otro-icon svg{width:26px;height:26px;stroke:#F1ECE0;}
  .otro-card h3{font-size:17px; font-weight:500;}
  .otro-card p{color:var(--muted); font-size:14px; margin:0; flex-grow:1;}
  .otro-footer{ display:flex; align-items:center; justify-content:space-between; margin-top:4px;}

  /* ---------- about ---------- */
  .about{
    display:grid; grid-template-columns:0.85fr 1.15fr; gap:56px; align-items:center;
  }
  .about-art{
    background:var(--forest-dark); border-radius:var(--radius);
    aspect-ratio:1/1; display:flex; align-items:center; justify-content:center;
    position:relative; overflow:hidden;
  }
  .about-art svg{width:58%;height:58%;}
  .about h2{font-size:clamp(26px,3vw,34px); margin-bottom:18px;}
  .about p{color:var(--muted); font-size:15.5px; max-width:520px;}
  .about p + p{margin-top:14px;}
  .signature{
    font-family:'Fraunces', serif; font-style:italic; font-size:19px;
    color:var(--forest-dark); margin-top:22px;
  }

  /* ---------- contacto ---------- */
  .contact{
    background:var(--forest-dark); color:#F1ECE0; border-radius:24px;
    padding:64px 56px; display:grid; grid-template-columns:1fr 1fr; gap:50px;
  }
  .contact h2{ color:#FBF8F1; font-size:clamp(26px,3vw,34px); }
  .contact p.lead{color:#D3CEBF; margin-top:14px; max-width:400px; font-size:15px;}
  .contact-list{ list-style:none; margin:28px 0 0; padding:0; display:flex; flex-direction:column; gap:16px;}
  .contact-list li{ display:flex; align-items:center; gap:12px; font-size:14.5px;}
  .contact-list svg{width:20px;height:20px; flex-shrink:0;}
  .contact-list a{text-decoration:none; color:#F1ECE0; font-weight:500;}
  .contact-list a:hover{color:#CFAE7F;}

  form{display:flex; flex-direction:column; gap:14px;}
  label{font-size:12.5px; font-weight:600; letter-spacing:.04em; text-transform:uppercase; color:#C7D0C0;}
  input, textarea{
    width:100%; padding:12px 14px; border-radius:10px; border:1px solid #48594B;
    background:#26392C; color:#F1ECE0; font-family:'Work Sans',sans-serif; font-size:14.5px;
  }
  input::placeholder, textarea::placeholder{color:#8A9A87;}
  textarea{resize:vertical; min-height:90px;}
  form .btn{ align-self:flex-start; margin-top:6px; }

  /* ---------- footer ---------- */
  footer{ padding:36px 0; }
  .foot-row{
    display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px;
    font-size:13px; color:var(--muted);
  }
  .foot-row .brand{font-size:16px;}

  /* ---------- responsive ---------- */
  @media (max-width:920px){
    .hero .wrap{grid-template-columns:1fr; padding-top:56px;}
    .hero-art{order:-1; max-width:280px; margin:0 auto;}
    .gallery{grid-template-columns:repeat(2,1fr);}
    .otros-grid{grid-template-columns:repeat(2,1fr);}
    .about{grid-template-columns:1fr;}
    .about-art{max-width:340px; margin:0 auto;}
    .contact{grid-template-columns:1fr; padding:44px 28px;}
    nav ul{display:none;}
    .menu-btn{display:flex;}
  }
  @media (max-width:600px){
    .gallery{grid-template-columns:1fr;}
    .otros-grid{grid-template-columns:1fr;}
    .section{padding:64px 0;}
  }
  @media (prefers-reduced-motion:reduce){
    html{scroll-behavior:auto;}
    .art-card, .btn{transition:none;}
  }
</style>
</head>
<body>

