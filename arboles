<main id="top">

  <!-- HERO -->
  <section class="hero">
    <div class="wrap">
      <div>
        <span class="eyebrow">Pintura al óleo y acrílico, hecha a mano</span>
        <h1>Cuadros de <em>árboles</em><br>para hogares con raíces</h1>
